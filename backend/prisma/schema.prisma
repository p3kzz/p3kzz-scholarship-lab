// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  name     String
  email    String @unique
  password String

  profile Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
}

model Profile {
  id Int @id @default(autoincrement())

  userId Int @unique

  user User @relation(fields: [userId], references: [id])

  fullName String?

  gender String?

  birthDate DateTime?

  nationality String? @default("Indonesia")

  province String?

  familyIncomeCategory String?

  fromUnderrepresentedRegion Boolean?

  currentDegreeLevel String?
  // example:
  // high_school
  // diploma
  // bachelors

  // future use
  targetDegreeLevel String?

  schoolName String?

  highSchoolTrack String?
  // example:
  // science
  // social
  // language

  schoolTier String?
  // example:
  // public_a
  // private_b

  expectedGraduationYear Int?

  reportAverage Float?

  mathScore Float?

  englishScore Float?

  majorSubjectAverage Float?

  extracurricularText String? @db.Text

  olympiadLevel String?
  // example:
  // city
  // province
  // national
  // international

  intendedCareerTrack String?
  // example:
  // tech
  // healthcare
  // business

  willingReturnHome Boolean?

  needsFullFunding Boolean?

  personalStatement String? @db.Text

  achievementsNarrative String? @db.Text

  futureGoals String? @db.Text

  isCompleted Boolean @default(false)

  skills Skill[]

  targetCountries TargetCountry[]

  languageCertificates LanguageCertificate[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Skill {
  id Int @id @default(autoincrement())

  profileId Int

  profile Profile @relation(fields: [profileId], references: [id])

  name String

  type SkillType

  createdAt DateTime @default(now())
}

enum SkillType {
  HARD
  SOFT
  LANGUAGE
}

model TargetCountry {
  id Int @id @default(autoincrement())

  profileId Int

  profile Profile @relation(fields: [profileId], references: [id])

  country String

  createdAt DateTime @default(now())
}

model LanguageCertificate {
  id Int @id @default(autoincrement())

  profileId Int

  profile Profile @relation(fields: [profileId], references: [id])

  name String
  // IELTS / TOEFL / TOPIK

  score String
  // 7.5 / 550 / Level 3

  createdAt DateTime @default(now())
}

model Scholarship {
  id Int @id @default(autoincrement())

  scholarshipId String @unique

  name String

  link String?

  eligibleNationalities Json?

  eligibleDegreeLevels Json?

  eligibleHighSchoolTracks Json?

  eligibleFields Json?

  preferredSchoolTier String?

  minAge Int?
  maxAge Int?

  minReportCardAverage   Float?
  minMajorSubjectAverage Float?

  languageRequirements Json?

  requiresFinancialNeed Boolean @default(false)

  maxFamilyIncomeCategory String?

  hostCountry String?
  hostRegion  String?

  selectionCriteria Json?

  careerTrackPreference String?

  requiresReturnHomeCountry Boolean @default(false)

  missionStatement String? @db.Text

  targetRecipientProfile String? @db.Text

  fundingCoversTuition   Boolean @default(false)
  fundingCoversLiving    Boolean @default(false)
  fundingCoversAirfare   Boolean @default(false)
  fundingCoversInsurance Boolean @default(false)

  fundingMonthlyStipend Float?

  fundingIsFullFunding Boolean @default(false)

  fundingCoverageCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
}

enum FeedbackType {
  click
  apply
  accepted
}

model Feedback {
  id Int @id @default(autoincrement())

  userId        Int
  scholarshipId Int

  feedbackType FeedbackType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId, feedbackType])
  @@index([userId])
  @@index([scholarshipId])
}
