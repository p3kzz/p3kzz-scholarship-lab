// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())

  name      String
  email     String   @unique
  password  String

  profile   Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id Int @id @default(autoincrement())

  // =========================
  // RELATION
  // =========================

  userId Int @unique

  user User @relation(fields: [userId], references: [id])

  // =========================
  // PERSONAL INFORMATION
  // =========================

  fullName String?

  gender String?

  birthDate DateTime?

  // otomatis "Indonesia"
  nationality String? @default("Indonesia")

  province String?

  familyIncomeCategory String?

  fromUnderrepresentedRegion Boolean?

  // =========================
  // ACADEMIC
  // =========================

  currentDegreeLevel String?
  // example:
  // high_school
  // diploma
  // bachelors

  // future use
  targetDegreeLevel String?

  schoolName String?

  highSchoolTrack String?
  // example:
  // science
  // social
  // language

  schoolTier String?
  // example:
  // public_a
  // private_b

  expectedGraduationYear Int?

  // =========================
  // ACADEMIC SCORES
  // =========================

  reportAverage Float?

  mathScore Float?

  englishScore Float?

  majorSubjectAverage Float?

  // =========================
  // ACHIEVEMENTS
  // =========================

  extracurricularText String? @db.Text

  olympiadLevel String?
  // example:
  // city
  // province
  // national
  // international

  // =========================
  // CAREER & GOALS
  // =========================

  intendedCareerTrack String?
  // example:
  // tech
  // healthcare
  // business

  willingReturnHome Boolean?

  needsFullFunding Boolean?

  // =========================
  // AI TEXT FIELDS
  // =========================

  personalStatement String? @db.Text

  achievementsNarrative String? @db.Text

  futureGoals String? @db.Text

  // =========================
  // STATUS
  // =========================

  isCompleted Boolean @default(false)

  // =========================
  // RELATIONS
  // =========================

  skills Skill[]

  targetCountries TargetCountry[]

  languageCertificates LanguageCertificate[]

  // =========================
  // TIMESTAMPS
  // =========================

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Skill {
  id Int @id @default(autoincrement())

  profileId Int

  profile Profile @relation(fields: [profileId], references: [id])

  name String

  type SkillType

  createdAt DateTime @default(now())
}

enum SkillType {
  HARD
  SOFT
  LANGUAGE
}

model TargetCountry {
  id Int @id @default(autoincrement())

  profileId Int

 profile Profile @relation(fields: [profileId], references: [id])

  country String

  createdAt DateTime @default(now())
}

model LanguageCertificate {
  id Int @id @default(autoincrement())

  profileId Int

  profile Profile @relation(fields: [profileId], references: [id])

  name String
  // IELTS / TOEFL / TOPIK

  score String
  // 7.5 / 550 / Level 3

  createdAt DateTime @default(now())
}
