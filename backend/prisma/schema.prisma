// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())

  name      String
  email     String   @unique
  password  String

  profile   Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id        Int      @id @default(autoincrement())

  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])

  //  IDENTITAS 
  fullName  String?
  gender    String?
  birthDate DateTime?

  nationality String?
  province    String?

  //  AKADEMIK 
  currentDegreeLevel String? // high_school
  targetDegreeLevel  String? // bachelors

  schoolName       String?
  highSchoolTrack  String?

  reportAverage       Float?
  mathScore           Float?
  englishScore        Float?
  majorSubjectAverage Float?

  expectedGraduationYear Int?

  //  ACHIEVEMENTS 
  olympiadLevel   String?

  leadershipCount Int?
  volunteerCount  Int?
  competitionCount Int?

  extracurricularText String? @db.Text

  //  BACKGROUND 
  familyIncomeCategory String?
  schoolTier           String?

  //  CAREER 
  intendedCareerTrack String?

  willingReturnHome Boolean?

  //  AI TEXT FIELDS 
  personalStatement      String? @db.Text
  achievementsNarrative  String? @db.Text
  futureGoals            String? @db.Text

  //  STATUS 
  isCompleted Boolean @default(false)

  //  RELATIONS 
  skills Skill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        Int @id @default(autoincrement())

  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id])

  name      String

  type      SkillType

  createdAt DateTime @default(now())
}

enum SkillType {
  HARD
  SOFT
  LANGUAGE
}
